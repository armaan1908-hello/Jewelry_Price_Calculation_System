CREATE TABLE Products (
  product_id INTEGER UNIQUE,
  category VARCHAR NOT NULL,  
  image_link VARCHAR,
  production_date DATE,
  PRIMARY KEY(product_id)
)
  

CREATE TABLE Cost_Estimates (
  estimate_id INTEGER AUTOINCREMENT,
  product_id INTEGER (FOREIGN KEY),
  silver_weight REAL,
  live_silver_price_p/g REAL (FOREIGN KEY)
  set_silver_price_p/g REAL (FOREIGN KEY)
  wastage_percent REAL,
  labor_cost REAL,
  stone_cost REAL,
  quantity INTEGER,
  wholesale_markup REAL,
  cost_per_pcs REAL,
  date_calculated DATE,
  wholesale_price REAL,
  PRIMARY KEY(estimate_id)
  FOREIGN KEY(product_id)
  FOREIGN KEY(
  FOREIGN KEY
  REFERENCES Products(product_id)
  REFERENCES Silver_Prices(live_silver_price_p/g)
  REFERENCES Silver_Prices(set_silver_price_p/g)
)

CREATE TABLE Silver_Prices (
  effective_date DATE PRIMARY KEY,
  live_silver_price_oz REAL,
  live_silver_price_p/g REAL,
  set_silver_price_oz REAL,
  set_silver_price_p/g REAL,
  currency VARCHAR(20),
  source VARCHAR(40)
)

CREATE TABLE Estimate_History (
  history_id INTEGER PRIMARY KEY AUTOINCREMENT,
  estimate_id INTEGER FOREIGN KEY,
  silver_price REAL,
  wholesale_price_per_pcs REAL,
  REFERENCES Cost_Estimates(estimate_id)
)

CREATE TABLE Stone_Library (
    stone_id INTEGER PRIMARY KEY AUTOINCREMENT,
    stone_name VARCHAR(50) NOT NULL UNIQUE,
    cost_per_piece REAL NOT NULL,
    supplier_id INTEGER FOREIGN KEY,
    colour VARCHAR(50),
    specs VARCHAR (300),
);

CREATE TABLE Suppliers (
    supplier_id INTEGER PRIMARY KEY AUTOINCREMENT,
    supplier_name VARCHAR(50) NOT NULL,
    supp_company_name VARCHAR(50),
    supp_contact_person VARCHAR(50),
    supp_phone_number VARCHAR(25),
    supp_email VARCHAR(70),
    supp_address VARCHAR(350),
    supp_country VARCHAR(50),
    supp_type VARCHAR (100),
);

CREATE TABLE Customers (
    customer_id INTEGER PRIMARY KEY AUTOINCREMENT,
    customer_name VARCHAR(50) NOT NULL,
    customer_company_name VARCHAR(50),
    customer_phone_number VARCHAR(25),
    customer_email VARCHAR(70),
    customer_address VARCHAR(350),
    customer_country VARCHAR(50),
    customer_specs VARCHAR (350),
);



